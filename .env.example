BOT_TOKEN=
GEMINI_API_KEY=
# Optional: comma-separated keys for rotation/failover
GEMINI_API_KEYS=
GEMINI_MODELS=gemini-2.5-flash,gemini-3-flash-preview
STRICT_CUTE_FALLBACK=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
FAST_MODE=true
CHAT_MAX_OUTPUT_TOKENS=120
TASK_MAX_OUTPUT_TOKENS=300
# Optional: override personality prompt
SYSTEM_PROMPT=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: model fallback list (first valid one will be used)
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,openai/gpt-oss-20b
